      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(git blame:*)",
      "Bash(git diff:*)",
      "Bash(git grep:*)",
      "Bash(git log:*)",
      "Bash(git ls-remote:*)",
      "Bash(git ls-tree:*)",
      "Bash(git rev-list:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(go:*)",
      "Bash(gofumpt:*)",
      "Bash(gocyclo:*)",
      "Bash(golangci-lint:*)",
      "Bash(grep:*)",
      "Bash(grpcurl:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(make build:*)",
      "Bash(make lint:*)",
      "Bash(make test:*)",
      "Bash(mkdir:*)",
      "Bash(openspec:*)",
      "Bash(sed -n:*)",
      "Bash(sleep:*)",
      "Bash(sort:*)",
